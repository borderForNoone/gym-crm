<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.25.xsd">

    <changeSet id="GIA-79 create-users-table" author="denys">
        <createTable tableName="users">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_users"/>
            </column>
            <column name="first_name" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="last_name" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="username" type="VARCHAR(110)">
                <constraints nullable="false"/>
            </column>
            <column name="password" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="is_active" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="GIA-79 add-pk-users" author="denys">
        <addUniqueConstraint
                tableName="users"
                columnNames="username"
                constraintName="uk_users_username"/>
    </changeSet>

    <changeSet id="GIA-79 create-training-types-table" author="denys">
        <createTable tableName="training_types">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_training_types"/>
            </column>
            <column name="training_type_name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="GIA-79 add-constraints-training-types" author="denys">
        <addUniqueConstraint
                tableName="training_types"
                columnNames="training_type_name"
                constraintName="uk_training_types_training_type_name"/>
    </changeSet>

    <changeSet id="GIA-79 create-trainees-table" author="denys">
        <createTable tableName="trainees">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_trainees"/>
            </column>
            <column name="date_of_birth" type="DATE"/>
            <column name="address" type="VARCHAR(255)"/>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="GIA-79 add-constraints-trainees" author="denys">
        <addForeignKeyConstraint
                baseTableName="trainees"
                baseColumnNames="user_id"
                referencedTableName="users"
                referencedColumnNames="id"
                constraintName="fk_trainees_user"/>
        <addUniqueConstraint
                tableName="trainees"
                columnNames="user_id"
                constraintName="uk_trainees_user"/>
    </changeSet>

    <changeSet id="GIA-79 create-trainers-table" author="denys">
        <createTable tableName="trainers">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_trainers"/>
            </column>
            <column name="specialization_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="GIA-79 add-constraints-trainers" author="denys">
        <addForeignKeyConstraint
                baseTableName="trainers"
                baseColumnNames="specialization_id"
                referencedTableName="training_types"
                referencedColumnNames="id"
                constraintName="fk_trainers_training_type"/>
        <addForeignKeyConstraint
                baseTableName="trainers"
                baseColumnNames="user_id"
                referencedTableName="users"
                referencedColumnNames="id"
                constraintName="fk_trainers_user"/>
        <addUniqueConstraint
                tableName="trainers"
                columnNames="user_id"
                constraintName="uk_trainers_user"/>
    </changeSet>

    <changeSet id="GIA-79 create-trainings-table" author="denys">
        <createTable tableName="trainings">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_trainings"/>
            </column>
            <column name="training_name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="training_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="training_duration" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="trainee_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="trainer_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="training_type_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="GIA-79 add-constraints-trainings" author="denys">
        <addForeignKeyConstraint
                baseTableName="trainings"
                baseColumnNames="trainee_id"
                referencedTableName="trainees"
                referencedColumnNames="id"
                constraintName="fk_trainings_trainee"
                onDelete="CASCADE"/>
        <addForeignKeyConstraint
                baseTableName="trainings"
                baseColumnNames="trainer_id"
                referencedTableName="trainers"
                referencedColumnNames="id"
                constraintName="fk_trainings_trainer"/>
        <addForeignKeyConstraint
                baseTableName="trainings"
                baseColumnNames="training_type_id"
                referencedTableName="training_types"
                referencedColumnNames="id"
                constraintName="fk_trainings_training_type"/>
    </changeSet>

    <changeSet id="GIA-79 create-trainees-trainers-table" author="denys">
        <createTable tableName="trainees_trainers">
            <column name="trainee_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="trainer_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="GIA-79 add-constraints-trainees-trainers" author="denys">
        <addPrimaryKey
                tableName="trainees_trainers"
                columnNames="trainee_id, trainer_id"
                constraintName="pk_trainees_trainers"/>
        <addForeignKeyConstraint
                baseTableName="trainees_trainers"
                baseColumnNames="trainee_id"
                referencedTableName="trainees"
                referencedColumnNames="id"
                constraintName="fk_trainees_trainers_trainee"/>
        <addForeignKeyConstraint
                baseTableName="trainees_trainers"
                baseColumnNames="trainer_id"
                referencedTableName="trainers"
                referencedColumnNames="id"
                constraintName="fk_trainees_trainers_trainer"/>
    </changeSet>

</databaseChangeLog>